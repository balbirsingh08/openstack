# OpenStack Auth (DevStack or real cloud)
OS_AUTH_URL=http://localhost:5000/v3
OS_USERNAME=admin
OS_PASSWORD=secret
OS_PROJECT_NAME=admin
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default

# App Config
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# Use mock mode if no real OpenStack available
USE_MOCK=true